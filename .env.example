# =============================================================================
# Sanan UMKM Maps — Template Environment Variables
# =============================================================================
# Salin file ini menjadi `.env.local` lalu isi nilainya:
#   cp .env.example .env.local
# ISI NILAI ASLI DI `.env.local`, BUKAN di file ini (file ini di-commit ke git).
#
# Keterangan:
#   [WAJIB]    aplikasi tidak berjalan benar tanpa ini
#   [OPSIONAL] fitur punya fallback/no-op bila dikosongkan
#   Variabel berawalan NEXT_PUBLIC_ akan terekspos ke browser — JANGAN taruh
#   secret/service key di variabel NEXT_PUBLIC_.
# =============================================================================


# --- Supabase [WAJIB] --------------------------------------------------------
# Dari Supabase Dashboard > Project Settings > API.
# URL proyek, mis. https://xxxxxxxxxxxx.supabase.co (atau http://127.0.0.1:54331 untuk lokal).
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# Anon/publishable key (aman dipakai di browser, dibatasi RLS).
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-atau-publishable-key>
# Service role key (RAHASIA — hanya dipakai server: seed script & upload). JANGAN commit.
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret-key>


# --- URL Aplikasi [WAJIB] ----------------------------------------------------
# Dipakai untuk redirect reset password / callback auth.
# Lokal: http://localhost:3000  |  Produksi: https://domain-anda.com
NEXT_PUBLIC_APP_URL=http://localhost:3000


# --- Routing / Rute jalan kaki [OPSIONAL] ------------------------------------
# openrouteservice (gratis ~2.000 request/hari): https://openrouteservice.org/dev
# Dipakai server-side untuk menggambar rute di peta (durasi jalan kaki asli).
# Kosong = fallback otomatis ke server demo OSRM (TIDAK disarankan untuk produksi).
OPENROUTESERVICE_API_KEY=


# --- Rate limiting login/signup [OPSIONAL, disarankan produksi] --------------
# Upstash Redis (gratis): https://upstash.com  > Create Database > REST API.
# Kosong = fallback in-memory (TIDAK efektif di serverless/Vercel — tiap instance terpisah).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# --- Error monitoring / Sentry [OPSIONAL] ------------------------------------
# DSN dari Sentry Dashboard > Project Settings > Client Keys (DSN).
# Kosong = Sentry non-aktif (no-op, tidak mengirim apa pun).
NEXT_PUBLIC_SENTRY_DSN=
# Berikut hanya untuk UPLOAD SOURCE MAP saat build/CI (opsional, boleh dikosongkan):
SENTRY_ORG=
SENTRY_PROJECT=
# Auth token dari Sentry > Settings > Auth Tokens (scope: project:releases). RAHASIA.
SENTRY_AUTH_TOKEN=


# --- Google Maps [OPSIONAL] --------------------------------------------------
# HANYA dipakai pengecek coverage Google Street View di dashboard owner
# (lib/actions/street-view-coverage.ts). Kosong = pengecek nonaktif (fitur inti
# peta/rute/360 TIDAK butuh ini). Aktifkan "Street View Static API" bila diisi.
GOOGLE_MAPS_API_KEY=
